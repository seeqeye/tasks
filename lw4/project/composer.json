{
    "name": "seeqeye/lw4",
    "description": "Cart and RateLimiter task",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": "^8.2"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.0",
        "squizlabs/php_codesniffer": "^3.11",
        "friendsofphp/php-cs-fixer": "^3.90"
    },
    "autoload": {
        "psr-4": {
            "Seeqeye\\Lw4\\": "src/"
        }
    },
    "scripts": {
        "lint": [
            "phpcs",
            "phpstan analyse src --level=8"
        ],
        "fix": [
            "php-cs-fixer fix"
        ]
    }
}